# Copy this file to .env and fill in your values

# Gemini API (free) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail SMTP
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here  # NOT your Gmail password — use App Password

# Recipient email (can be same as GMAIL_ADDRESS)
RECIPIENT_EMAIL=your_email@gmail.com

# Reddit API (free) — https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=tech-news-agent/1.0
